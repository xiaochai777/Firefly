---
// Admin
---
<!doctype html>
<html lang="zh-CN">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="robots" content="noindex" />
  <title>Blog Admin</title>
  <style>
    * { margin: 0; padding: 0; box-sizing: border-box; }
    body { font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, "PingFang SC", "Microsoft YaHei", sans-serif; background: #f5f5f5; }
    .login-box { max-width: 400px; margin: 100px auto; background: #fff; padding: 40px; border-radius: 12px; box-shadow: 0 2px 12px rgba(0,0,0,0.1); text-align: center; }
    .login-box h2 { margin-bottom: 20px; color: #333; }
    .login-box p { color: #666; margin-bottom: 20px; }
    .login-box input { width: 100%; padding: 12px; border: 1px solid #ddd; border-radius: 8px; margin-bottom: 16px; font-size: 14px; }
    .login-box button { width: 100%; padding: 12px; background: #6366f1; color: #fff; border: none; border-radius: 8px; font-size: 16px; cursor: pointer; }
    .login-box button:hover { background: #4f46e5; }
    .dashboard { max-width: 900px; margin: 20px auto; padding: 20px; }
    .header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 20px; }
    .header h1 { color: #333; }
    .btn { padding: 10px 20px; border: none; border-radius: 8px; cursor: pointer; font-size: 14px; margin: 2px; }
    .btn-primary { background: #6366f1; color: #fff; }
    .btn-danger { background: #ef4444; color: #fff; }
    .btn-secondary { background: #e5e7eb; color: #333; }
    .post-list { background: #fff; border-radius: 12px; box-shadow: 0 2px 8px rgba(0,0,0,0.06); overflow: hidden; }
    .post-item { padding: 16px 20px; border-bottom: 1px solid #f0f0f0; display: flex; justify-content: space-between; align-items: center; }
    .post-item:last-child { border-bottom: none; }
    .post-title { font-weight: 600; color: #333; }
    .editor { background: #fff; border-radius: 12px; padding: 24px; box-shadow: 0 2px 8px rgba(0,0,0,0.06); }
    .editor input, .editor textarea { width: 100%; padding: 12px; border: 1px solid #ddd; border-radius: 8px; margin-bottom: 12px; font-size: 14px; font-family: inherit; }
    .editor textarea { min-height: 400px; resize: vertical; }
    .editor label { font-weight: 600; color: #555; margin-bottom: 4px; display: block; }
    .actions { display: flex; gap: 10px; margin-top: 16px; }
    .hidden { display: none; }
    .msg { padding: 12px; border-radius: 8px; margin-bottom: 16px; }
    .msg-ok { background: #d1fae5; color: #065f46; }
    .msg-err { background: #fee2e2; color: #991b1b; }
    .loading { text-align: center; padding: 40px; color: #999; }
  </style>
</head>
<body>
  <div id="loginView" class="login-box">
    <h2>&#128274; Blog Admin</h2>
    <p>Enter GitHub Token to login</p>
    <input type="password" id="tokenInput" placeholder="ghp_xxxx" />
    <button onclick="doLogin()">Login</button>
    <p id="loginErr" style="color:red;margin-top:10px;" class="hidden"></p>
  </div>

  <div id="dashboardView" class="dashboard hidden">
    <div class="header">
      <h1>&#128221; Posts</h1>
      <div>
        <button class="btn btn-primary" onclick="showEditor()">+ New Post</button>
        <button class="btn btn-secondary" onclick="logout()">Logout</button>
      </div>
    </div>
    <div id="msg" class="hidden"></div>
    <div id="postList" class="post-list"><div class="loading">Loading...</div></div>
  </div>

  <div id="editorView" class="dashboard hidden">
    <div class="editor">
      <h2 style="margin-bottom:20px;">&#9997; <span id="editorTitle">New Post</span></h2>
      <div id="editorMsg" class="hidden"></div>
      <label>Title</label>
      <input type="text" id="postTitle" placeholder="Post title" />
      <label>Slug (English filename)</label>
      <input type="text" id="postSlug" placeholder="my-first-post" />
      <label>Date</label>
      <input type="date" id="postDate" />
      <label>Description</label>
      <input type="text" id="postDesc" placeholder="Short description" />
      <label>Tags (comma separated)</label>
      <input type="text" id="postTags" placeholder="tech, life" />
      <label>Content (Markdown)</label>
      <textarea id="postBody" placeholder="Write your post here..."></textarea>
      <div class="actions">
        <button class="btn btn-primary" onclick="savePost()">Save</button>
        <button class="btn btn-secondary" onclick="showDashboard()">Back</button>
      </div>
    </div>
  </div>

  <script is:inline>
    const REPO = "xiaochai777/Firefly";
    const BRANCH = "master";
    const POSTS_PATH = "src/content/posts";
    let currentToken = localStorage.getItem("gh_token");
    let editingFile = null;

    if (currentToken) showDashboard();

    function doLogin() {
      const token = document.getElementById("tokenInput").value.trim();
      if (!token) return;
      fetch("https://api.github.com/user", {
        headers: { "Authorization": "token " + token }
      }).then(function(r) {
        if (!r.ok) throw new Error("Invalid token");
        return r.json();
      }).then(function(user) {
        localStorage.setItem("gh_token", token);
        currentToken = token;
        showDashboard();
      }).catch(function(e) {
        var el = document.getElementById("loginErr");
        el.textContent = e.message;
        el.classList.remove("hidden");
      });
    }

    function logout() {
      localStorage.removeItem("gh_token");
      currentToken = null;
      location.reload();
    }

    function showDashboard() {
      document.getElementById("loginView").classList.add("hidden");
      document.getElementById("editorView").classList.add("hidden");
      document.getElementById("dashboardView").classList.remove("hidden");
      loadPosts();
    }

    function showEditor(file) {
      editingFile = file || null;
      document.getElementById("dashboardView").classList.add("hidden");
      document.getElementById("editorView").classList.remove("hidden");
      document.getElementById("editorTitle").textContent = file ? "Edit Post" : "New Post";
      if (file) {
        document.getElementById("postTitle").value = file.title || "";
        document.getElementById("postSlug").value = file.name.replace(".md", "");
        document.getElementById("postSlug").disabled = true;
        document.getElementById("postDate").value = file.published || "";
        document.getElementById("postDesc").value = file.description || "";
        document.getElementById("postTags").value = (file.tags || []).join(", ");
        document.getElementById("postBody").value = file.body || "";
      } else {
        document.getElementById("postTitle").value = "";
        document.getElementById("postSlug").value = "";
        document.getElementById("postSlug").disabled = false;
        document.getElementById("postDate").value = new Date().toISOString().split("T")[0];
        document.getElementById("postDesc").value = "";
        document.getElementById("postTags").value = "";
        document.getElementById("postBody").value = "";
      }
    }

    function showMsg(id, text, ok) {
      var el = document.getElementById(id);
      el.textContent = text;
      el.className = "msg " + (ok ? "msg-ok" : "msg-err");
      el.classList.remove("hidden");
      setTimeout(function() { el.classList.add("hidden"); }, 3000);
    }

    function api(path, method, body) {
      var opts = {
        method: method || "GET",
        headers: {
          "Authorization": "token " + currentToken,
          "Accept": "application/vnd.github.v3+json"
        }
      };
      if (body) opts.body = JSON.stringify(body);
      return fetch("https://api.github.com/repos/" + REPO + "/contents/" + path, opts)
        .then(function(r) {
          if (!r.ok) return r.json().then(function(e) { throw new Error(e.message); });
          return r.json();
        });
    }

    function loadPosts() {
      api(POSTS_PATH).then(function(files) {
        var mdFiles = files.filter(function(f) { return f.name.endsWith(".md") && f.name !== "_draft.md"; });
        var listEl = document.getElementById("postList");
        if (mdFiles.length === 0) {
          listEl.innerHTML = '<div class="loading">No posts yet. Click "+ New Post" to start!</div>';
          return;
        }
        var html = "";
        mdFiles.forEach(function(f) {
          html += '<div class="post-item"><div class="post-title">' + f.name.replace(".md","") + '</div><div><button class="btn btn-secondary" onclick="editPost(\'' + f.path + '\',\'' + f.sha + '\')">Edit</button> <button class="btn btn-danger" onclick="deletePost(\'' + f.path + '\',\'' + f.sha + '\',\'' + f.name + '\')">Delete</button></div></div>';
        });
        listEl.innerHTML = html;
      }).catch(function(e) {
        document.getElementById("postList").innerHTML = '<div class="msg msg-err">Error: ' + e.message + '</div>';
      });
    }

    function editPost(path, sha) {
      api(path).then(function(data) {
        var content = decodeURIComponent(escape(atob(data.content.replace(/\n/g, ""))));
        var match = content.match(/^---\n([\s\S]*?)\n---\n([\s\S]*)$/);
        var title = "", published = "", description = "", tags = [], body = content;
        if (match) {
          var fm = match[1];
          body = match[2];
          var t = fm.match(/title:\s*"?([^"\n]+)"?/);
          var p = fm.match(/published:\s*(.+)/);
          var d = fm.match(/description:\s*"?([^"\n]+)"?/);
          var tg = fm.match(/tags:\s*\[([^\]]*)\]/);
          if (t) title = t[1].trim();
          if (p) published = p[1].trim();
          if (d) description = d[1].trim();
          if (tg) tags = tg[1].split(",").map(function(s) { return s.trim().replace(/"/g,""); });
        }
        showEditor({ name: path.split("/").pop(), title: title, published: published, description: description, tags: tags, body: body, sha: sha, path: path });
      }).catch(function(e) {
        showMsg("msg", "Error: " + e.message, false);
      });
    }

    function savePost() {
      var title = document.getElementById("postTitle").value.trim();
      var slug = document.getElementById("postSlug").value.trim();
      var date = document.getElementById("postDate").value;
      var desc = document.getElementById("postDesc").value.trim();
      var tags = document.getElementById("postTags").value.trim();
      var body = document.getElementById("postBody").value;
      if (!title || !slug) { showMsg("editorMsg", "Title and slug required", false); return; }

      var tagsYaml = tags ? "[" + tags.split(",").map(function(t) { return '"' + t.trim() + '"'; }).join(", ") + "]" : "[]";
      var raw = '---\ntitle: "' + title + '"\npublished: ' + date + '\ndescription: "' + desc + '"\ntags: ' + tagsYaml + '\n---\n' + body;
      var encoded = btoa(unescape(encodeURIComponent(raw)));

      var filePath = POSTS_PATH + "/" + slug + ".md";
      var sha = editingFile ? editingFile.sha : null;

      var doSave = function() {
        var payload = { message: (editingFile ? "update" : "new post") + ": " + title, content: encoded };
        if (sha) payload.sha = sha;
        return api(filePath, "PUT", payload);
      };

      if (!sha) {
        api(filePath).then(function(existing) { sha = existing.sha; }).catch(function() {}).then(doSave);
      } else {
        doSave().then(function() {
          showMsg("editorMsg", "Saved!", true);
          editingFile = null;
          setTimeout(showDashboard, 1000);
        }).catch(function(e) {
          showMsg("editorMsg", "Error: " + e.message, false);
        });
        return;
      }

      setTimeout(function() {
        doSave().then(function() {
          showMsg("editorMsg", "Saved!", true);
          editingFile = null;
          setTimeout(showDashboard, 1000);
        }).catch(function(e) {
          showMsg("editorMsg", "Error: " + e.message, false);
        });
      }, 500);
    }

    function deletePost(path, sha, name) {
      if (!confirm("Delete " + name + "?")) return;
      api(path, "DELETE", { message: "delete: " + name, sha: sha }).then(function() {
        showMsg("msg", "Deleted!", true);
        loadPosts();
      }).catch(function(e) {
        showMsg("msg", "Error: " + e.message, false);
      });
    }
  </script>
</body>
</html>